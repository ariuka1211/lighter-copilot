# Lighter Copilot — Environment Variables
# Copy to .env and fill in your values

# Lighter API
LIGHTER_API_PRIVATE_KEY=your_api_private_key_here
LIGHTER_ACCOUNT_INDEX=719758

# Proxy (Webshare or similar)
LIGHTER_PROXY_USER=your_proxy_username
LIGHTER_PROXY_PASS=your_proxy_password
LIGHTER_PROXY_HOST=64.137.96.74
LIGHTER_PROXY_PORT=6641

# Telegram Alerts
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
